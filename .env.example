# ============================================================================
# Root environment for docker-compose. Copy to `.env` and adjust.
# ============================================================================

# --- Database ---
DB_NAME=resume_analyzer
DB_USERNAME=resume_user
DB_PASSWORD=resume_pass

# --- Backend ---
SPRING_PROFILES_ACTIVE=prod
# Base64-encoded 256-bit secret. Generate: openssl rand -base64 48
JWT_SECRET=Y2hhbmdlLXRoaXMtc2VjcmV0LWluLXByb2R1Y3Rpb24tcGxlYXNlLW5vdy0xMjM0NQ==

# Default admin seeded on first boot — CHANGE THESE.
ADMIN_EMAIL=admin@resume-analyzer.dev
ADMIN_PASSWORD=Admin@12345

# CORS origins allowed to call the API (frontend URL).
CORS_ALLOWED_ORIGINS=http://localhost:8081

# --- AI provider: mock (offline, default) | openai | gemini ---
AI_PROVIDER=mock
OPENAI_API_KEY=
GEMINI_API_KEY=
